# =============================================================================
# .env.example
# Template for all environment variables needed to run the project.
#
# HOW TO USE THIS FILE:
#   1. Copy this file to .env in the project root:
#         cp .env.example .env        (Mac/Linux)
#         copy .env.example .env      (Windows)
#   2. Fill in every value marked  ← FILL THIS IN
#   3. Never commit .env to Git — it is in .gitignore
#   4. When you add a new variable, add it here too (with a placeholder)
#      and tell the other two developers to update their .env files
#
# WHO FILLS IN WHAT:
#   Developer 1  — Flask core, Auth0, database
#   Developer 2  — no new variables (uses same database)
#   Developer 3  — Stripe, SendGrid
#
# ON THE SERVER:
#   Do not upload a .env file to the server.
#   Set each variable directly in your hosting platform:
#     AWS         — Systems Manager Parameter Store or Secrets Manager
#     DigitalOcean — App Platform → Environment Variables
#     Plain VPS   — export VAR=value in /etc/environment or via systemd
#
# STRIDE Info Disclosure:
#   This file contains only placeholder values — no real secrets.
#   The real .env file must never be committed, shared over chat,
#   or included in bug reports. Treat it like a password.
# =============================================================================


# -----------------------------------------------------------------------------
# Flask core
# -----------------------------------------------------------------------------

# Environment: development | testing | production
FLASK_ENV=development

# Secret key — signs session cookies and CSRF tokens.
# Generate a strong one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# STRIDE Tampering: a weak or guessable key lets attackers forge cookies.
SECRET_KEY=← FILL THIS IN - generate a long random string


# -----------------------------------------------------------------------------
# Database
# Developer 1 sets this up. Dev 2 and Dev 3 use the same value.
# -----------------------------------------------------------------------------

# Local development — SQLite (no installation needed)
# DATABASE_URL=sqlite:///ecommerce_dev.db

# MySQL — use this format when connecting to a real MySQL server
# Local MySQL:
# DATABASE_URL=mysql+pymysql://root:yourpassword@localhost:3306/ecommerce
#
# Remote MySQL / managed database (AWS RDS, DigitalOcean, PlanetScale):
# DATABASE_URL=mysql+pymysql://username:password@host:3306/ecommerce
#
# Production always uses MySQL — never SQLite.
DATABASE_URL=sqlite:///ecommerce_dev.db


# -----------------------------------------------------------------------------
# Auth0
# Developer 1 sets these up. Dev 2 and Dev 3 use the same values.
#
# Where to find these:
#   1. Go to https://manage.auth0.com
#   2. Create a new Application → Single Page Application (for Next.js)
#   3. Create a new API → set a unique identifier (this is AUTH0_AUDIENCE)
#   4. Under Application Settings → copy Domain and Client ID
#
# STRIDE Spoofing:
#   AUTH0_DOMAIN verifies the JWT issuer.
#   AUTH0_AUDIENCE verifies the JWT audience.
#   Both must be exact — no trailing slashes.
# -----------------------------------------------------------------------------

# Your Auth0 tenant domain
# Format:  yourappname.auth0.com
# Example: myshop.us.auth0.com
AUTH0_DOMAIN=← FILL THIS IN - e.g. yourapp.auth0.com

# Your Auth0 API identifier (set when you create the API in Auth0 dashboard)
# Format:  https://api.yourapp.com   (this is a URI — does not need to exist)
# Example: https://api.myshop.com
AUTH0_AUDIENCE=← FILL THIS IN - e.g. https://api.yourapp.com

# Auth0 Client ID — used by Next.js frontend, not Flask directly
# Included here so the whole team has it in one place
# Found in: Auth0 Dashboard → Applications → your app → Client ID
AUTH0_CLIENT_ID=← FILL THIS IN

# Auth0 Client Secret — used by Next.js backend (Next.js API routes)
# Found in: Auth0 Dashboard → Applications → your app → Client Secret
# NEVER send this to the browser. Next.js server-side only.
AUTH0_CLIENT_SECRET=← FILL THIS IN


# -----------------------------------------------------------------------------
# Frontend (Next.js)
# Used for CORS whitelist and browser redirects.
# -----------------------------------------------------------------------------

# URL where your Next.js app is running
# Development:  http://localhost:3000
# Production:   https://yourshop.vercel.app  (or your custom domain)
FRONTEND_URL=http://localhost:3000


# -----------------------------------------------------------------------------
# Redis
# Used by Flask-Limiter for rate limiting in production.
# In development, leave this as memory:// — rate limits reset on restart.
#
# Install Redis locally (optional for dev):
#   Windows: https://github.com/microsoftarchive/redis/releases
#   Mac:     brew install redis && brew services start redis
# -----------------------------------------------------------------------------

# Development (in-memory, no Redis needed)
REDIS_URL=memory://

# Production (Redis server)
# REDIS_URL=redis://localhost:6379
# REDIS_URL=redis://:password@yourredishost:6379   (with password)


# -----------------------------------------------------------------------------
# Stripe (Developer 3 fills these in)
# https://dashboard.stripe.com → Developers → API Keys
#
# Test keys (use during development — no real money moves):
#   Secret key starts with:      sk_test_
#   Publishable key starts with: pk_test_
#
# Live keys (production only — real money):
#   Secret key starts with:      sk_live_
#   Publishable key starts with: pk_live_
#
# NEVER use live keys in development.
# NEVER commit real Stripe keys to Git.
# STRIDE Spoofing: STRIPE_WEBHOOK_SECRET verifies webhook requests are
# genuinely from Stripe and not from an attacker faking a payment event.
# -----------------------------------------------------------------------------

# Server-side secret key — never sent to the browser
STRIPE_SECRET_KEY=← FILL THIS IN - sk_test_...

# Publishable key — safe to send to Next.js frontend
STRIPE_PUBLISHABLE_KEY=← FILL THIS IN - pk_test_...

# Webhook signing secret — verifies Stripe webhook POST requests
# Found in: Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret
# Starts with: whsec_
STRIPE_WEBHOOK_SECRET=← FILL THIS IN - whsec_...


# -----------------------------------------------------------------------------
# SendGrid (Developer 3 fills these in)
# Used for order confirmation and order failed emails.
# https://app.sendgrid.com → Settings → API Keys → Create API Key
#
# Auth0 handles all auth emails (verification, password reset, MFA).
# SendGrid handles only transactional order emails.
#
# Free tier: 100 emails/day — enough for development and small launches.
# -----------------------------------------------------------------------------

# SendGrid API key — starts with SG.
SENDGRID_API_KEY=← FILL THIS IN - SG...

# The email address order confirmations are sent from.
# Must be a verified sender in your SendGrid account.
# https://app.sendgrid.com → Settings → Sender Authentication
MAIL_DEFAULT_SENDER=noreply@← FILL THIS IN - yourshop.com


# -----------------------------------------------------------------------------
# Mail / SMTP (alternative to SendGrid direct API)
# Flask-Mail uses these if you prefer SMTP over the SendGrid SDK.
# If you use the SendGrid SDK directly (recommended), you can leave
# these as-is and just set SENDGRID_API_KEY above.
# -----------------------------------------------------------------------------

MAIL_SERVER=smtp.sendgrid.net
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=apikey
# MAIL_PASSWORD is the same as your SENDGRID_API_KEY when using SendGrid SMTP
MAIL_PASSWORD=← FILL THIS IN - same as SENDGRID_API_KEY


# =============================================================================
# QUICK SETUP CHECKLIST
# Fill these in before running the project for the first time:
#
# Developer 1:
#   [ ] SECRET_KEY          — generate with python -c "import secrets; print(secrets.token_hex(32))"
#   [ ] DATABASE_URL        — leave as SQLite for local dev, MySQL for production
#   [ ] AUTH0_DOMAIN        — from Auth0 dashboard
#   [ ] AUTH0_AUDIENCE      — from Auth0 dashboard (your API identifier)
#   [ ] AUTH0_CLIENT_ID     — from Auth0 dashboard
#   [ ] AUTH0_CLIENT_SECRET — from Auth0 dashboard
#   [ ] FRONTEND_URL        — http://localhost:3000 for local dev
#
# Developer 3:
#   [ ] STRIPE_SECRET_KEY       — from Stripe dashboard (test key)
#   [ ] STRIPE_PUBLISHABLE_KEY  — from Stripe dashboard (test key)
#   [ ] STRIPE_WEBHOOK_SECRET   — from Stripe dashboard (after creating webhook)
#   [ ] SENDGRID_API_KEY        — from SendGrid dashboard
#   [ ] MAIL_DEFAULT_SENDER     — your verified sender email in SendGrid
#
# All developers:
#   [ ] Copy this file to .env
#   [ ] Confirm .env is in .gitignore before first git push
#   [ ] Never share .env over chat, email, or in a PR comment
# =============================================================================
