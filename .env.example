# .env.example
# Copy this to .env and fill in your values.
# NEVER commit .env to Git — it is in .gitignore.

# Flask
FLASK_ENV=development
SECRET_KEY=change-me-to-a-long-random-string-in-production

# Database (use PostgreSQL URL in production)
DATABASE_URL=sqlite:///ecommerce_dev.db

# Email (SMTP)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@shopname.com

# Redis (rate limiting in production; leave as memory:// for local dev)
REDIS_URL=memory://

# Payment webhook secret (Developer 3 — set this when integrating payment gateway)
PAYMENT_WEBHOOK_SECRET=change-me-to-gateway-provided-secret
