# =============================================================================
# .gitignore
# Files that must NEVER be committed to Git.
# Copy this to the project root.
# =============================================================================

# ── Secrets — most important ──────────────────────────────────────────────────
.env
*.pem
*.key
secrets.json

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environment ───────────────────────────────────────────────────────
venv/
.venv/
env/
ENV/

# ── Database files ────────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ── Flask / instance folder ───────────────────────────────────────────────────
instance/
.webassets-cache

# ── Testing ───────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
